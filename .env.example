# Copy this file to .env and fill in real values.
# Set all of these as Vercel environment variables — do NOT commit .env.

# Neon PostgreSQL connection string (set on Vercel only)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Privy app credentials — App ID is public, Secret is server-only
PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# Baked into the client bundle at build time (non-sensitive — same as PRIVY_APP_ID)
VITE_PRIVY_APP_ID="your-privy-app-id"
